# Supabase credentials — copy this file to .env.local and fill in your values
# Get them from: https://supabase.com → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# VAPID public key for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
# Then set VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY as Supabase secrets:
#   supabase secrets set VAPID_PUBLIC_KEY=<key> VAPID_PRIVATE_KEY=<key>
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
